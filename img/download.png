<svg width="600" height="220" viewBox="0 0 600 220" xmlns="http://www.w3.org/2000/svg">

  <!-- Fundo opcional -->
  <rect width="100%" height="100%" fill="black"></rect>

  <!-- Texto fm -->
  <text x="40" y="120" font-family="Segoe UI, Arial, sans-serif" font-size="120" fill="#E5E7EB" font-weight="300">
    fm
  </text>

  <!-- Texto tic -->
  <text x="230" y="120" font-family="Segoe UI, Arial, sans-serif" font-size="120" fill="#38BDF8" font-weight="500">
    tic
  </text>

  <!-- Peças (mais alinhadas) -->
  <rect x="410" y="40" width="28" height="28" rx="6" fill="#22C55E"></rect>
  <rect x="450" y="20" width="28" height="28" rx="6" fill="#F59E0B"></rect>
  <rect x="445" y="70" width="28" height="28" rx="6" fill="#6366F1"></rect>

  <!-- Texto menor -->
  <text x="45" y="170" font-family="Segoe UI, Arial, sans-serif" font-size="32" fill="#E5E7EB" opacity="0.8">
    service desk
  </text>

</svg>